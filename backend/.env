# Micro Infoweb Backend Environment Variables

# Security
SECRET_KEY=django-insecure-change-me-in-production-micro-infoweb-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database Configuration (MySQL / SQLite)
# To use MySQL: Set DB_ENGINE=mysql, and fill in DB_NAME, DB_USER, DB_PASSWORD, DB_HOST, DB_PORT
# To use local SQLite fallback: Set DB_ENGINE=sqlite
DB_ENGINE=mysql
DB_NAME=micro_infoweb_db
DB_USER=root
DB_PASSWORD=playstation@5
DB_HOST=127.0.0.1
DB_PORT=3306

# JWT Authentication
JWT_SECRET_KEY=super-secret-jwt-key-for-micro-infoweb
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS & Frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
